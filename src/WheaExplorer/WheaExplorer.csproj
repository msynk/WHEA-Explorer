<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>WheaExplorer</AssemblyName>
    <RootNamespace>WheaExplorer</RootNamespace>
    <Title>WHEA Explorer</Title>
    <Version>1.0.0</Version>
    <!-- Ported hardware-event parser predates nullable annotations; suppress bulk noise. -->
    <NoWarn>$(NoWarn);CS8618;CS8625;CS8765</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

</Project>
